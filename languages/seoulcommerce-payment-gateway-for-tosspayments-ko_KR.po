#: woocommerce-tosspayments.php:96
msgid "SeoulCommerce Payment Gateway for TossPayments requires WooCommerce to be installed and active."
msgstr "SeoulCommerce Payment Gateway for TossPayments는 WooCommerce가 설치되고 활성화되어 있어야 합니다."

#: includes/class-wc-tosspayments-gateway.php:29
msgid "SeoulCommerce Payment Gateway for TossPayments"
msgstr "SeoulCommerce 토스페이먼츠 결제 게이트웨이"

#: includes/class-wc-tosspayments-gateway.php:30
msgid "Accept card payments using TossPayments."
msgstr "토스페이먼츠를 사용하여 카드 결제를 받으세요."

#: includes/class-wc-tosspayments-gateway.php:78
msgid "Enable/Disable"
msgstr "활성화/비활성화"

#: includes/class-wc-tosspayments-gateway.php:79
msgid "Enable TossPayments"
msgstr "토스페이먼츠 활성화"

#: includes/class-wc-tosspayments-gateway.php:83
msgid "Title"
msgstr "제목"

#: includes/class-wc-tosspayments-gateway.php:85
msgid "This controls the title which the user sees during checkout."
msgstr "체크아웃 시 사용자에게 표시되는 제목을 설정합니다."

#: includes/class-wc-tosspayments-gateway.php:86
msgid "Toss Payments"
msgstr "토스페이먼츠"

#: includes/class-wc-tosspayments-gateway.php:90
msgid "Description"
msgstr "설명"

#: includes/class-wc-tosspayments-gateway.php:92
msgid "This controls the description which the user sees during checkout."
msgstr "체크아웃 시 사용자에게 표시되는 설명을 설정합니다."

#: includes/class-wc-tosspayments-gateway.php:93
msgid "Pay securely using Toss Payments."
msgstr "토스페이먼츠를 사용하여 안전하게 결제하세요."

#: includes/class-wc-tosspayments-gateway.php:97
msgid "Test Mode"
msgstr "테스트 모드"

#: includes/class-wc-tosspayments-gateway.php:99
msgid "Enable test mode"
msgstr "테스트 모드 활성화"

#: includes/class-wc-tosspayments-gateway.php:100
msgid "Enable this to use test API keys and sandbox environment."
msgstr "테스트 API 키 및 샌드박스 환경을 사용하려면 활성화하세요."

#: includes/class-wc-tosspayments-gateway.php:105
msgid "Test Client Key"
msgstr "테스트 클라이언트 키"

#: includes/class-wc-tosspayments-gateway.php:107
msgid "Get your test API keys from TossPayments dashboard."
msgstr "토스페이먼츠 대시보드에서 테스트 API 키를 확인하세요."

#: includes/class-wc-tosspayments-gateway.php:112
msgid "Test Secret Key"
msgstr "테스트 시크릿 키"

#: includes/class-wc-tosspayments-gateway.php:114
msgid "Get your test secret key from TossPayments dashboard."
msgstr "토스페이먼츠 대시보드에서 테스트 시크릿 키를 확인하세요."

#: includes/class-wc-tosspayments-gateway.php:119
msgid "Live Client Key"
msgstr "라이브 클라이언트 키"

#: includes/class-wc-tosspayments-gateway.php:121
msgid "Get your live API keys from TossPayments dashboard."
msgstr "토스페이먼츠 대시보드에서 라이브 API 키를 확인하세요."

#: includes/class-wc-tosspayments-gateway.php:126
msgid "Live Secret Key"
msgstr "라이브 시크릿 키"

#: includes/class-wc-tosspayments-gateway.php:128
msgid "Get your live secret key from TossPayments dashboard."
msgstr "토스페이먼츠 대시보드에서 라이브 시크릿 키를 확인하세요."

#: includes/class-wc-tosspayments-gateway.php:133
msgid "Debug Mode"
msgstr "디버그 모드"

#: includes/class-wc-tosspayments-gateway.php:135
msgid "Enable debug mode"
msgstr "디버그 모드 활성화"

#: includes/class-wc-tosspayments-gateway.php:136
msgid "Log payment events for debugging."
msgstr "디버깅을 위해 결제 이벤트를 로그로 남깁니다."

#: includes/class-wc-tosspayments-gateway.php:421
#: assets/js/payment.js
msgid "Processing payment..."
msgstr "결제를 처리하는 중..."

#: includes/class-wc-tosspayments-gateway.php:422
#: assets/js/payment.js
msgid "Payment failed. Please try again."
msgstr "결제에 실패했습니다. 다시 시도해주세요."

#: includes/class-wc-tosspayments-gateway.php:475
msgid "TossPayments payment approved. Payment Key: %1$s, TossPayments Order ID: %2$s"
msgstr "토스페이먼츠 결제가 승인되었습니다. 결제 키: %1$s, 토스페이먼츠 주문 ID: %2$s"

